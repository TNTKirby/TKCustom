	"$phong"		"1"
	"$phongexponent"		"12.000000"
	"$phongboost"		"12.000000"
	"$phongfresnelranges"		"[.25 .5 1]"
	"$rimlight"		"1"
	"$rimlightexponent"		"4"
	"$rimlightboost"		"3.000000"
	"$rimmask"		"1"
	"$halflambert"		"1"
	"$color2"		"{ 255 255 255 }"
