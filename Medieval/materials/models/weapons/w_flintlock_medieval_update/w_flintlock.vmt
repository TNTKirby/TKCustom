"VertexlitGeneric"
{
	"$baseTexture" "models/weapons/w_flintlock_medieval_update/w_flintlock_test"
	"$bumpmap" "models/weapons/w_flintlock_medieval_update/w_flintlock_normal"
	"$halflambert" "1"

	"$envmap" "env_cubemap"
	
	"$phong" "1"
	"$phongexponent" "15"
	"$phongboost" ".3"	
	"$lightwarptexture" "models/weapons/c_items/c_ambassador_lightwarp"
//	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[1 2 10]"

	"$glowcolor" "1"
	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
