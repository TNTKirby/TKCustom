
"VertexlitGeneric"
{
	"$basetexture" "models/weapons/w_ribs_medieval/platex"


$BASEMAPALPHAPHONGMASK 1

	"$phong" "1"
	"$phongexponent" "2"
	"$phongboost" "0.2"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.25 .5 1]"

	"$rimlight" "0"
	"$rimlightexponent" "0.2"	
	"$rimlightboost" ".08"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
