"VertexLitGeneric"
{
	"$baseTexture" "models/props_medieval/medieval_windows_doors"
//	"$bumpmap" "models/props_medieval/medieval_windows_doors_normal"

	"$basealphaenvmapmask" 1
	"$envmap" "env_cubemap"
	"$envmaptint" "[.5 .5 .5]"

	$halflambert 1

//	"$phong" "1"
	"$phongexponent" "20"
	"$phongboost" "10"	
//	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.3 .5 3]"
	"$basemapalphaphongmask" "1"
	
	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" ".2"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}