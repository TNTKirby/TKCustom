"VertexlitGeneric"
{
	"$baseTexture" "models\weapons\w_throwingaxe_jukebox\c_throwingaxe_bloody"

	"$envmap" "env_cubemap"
	"$envmaptint" "[.1 .1 .1]"
	"$basealphaenvmapmask"		"1"


	"$phong" "1"
	"$phongexponent" "20"
	"$phongboost" "1"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.5 .5 3]"
	"$halflambert" "1"

	"$tempvar" "0"

	"$basephongexponent" "15"
	"$basephongboost" "10"

	"$commadd_phongexponent" "30"
	"$commadd_phongboost" 	"22.5"
	"$commweapon"		"0"

	"$basemapalphaphongmask" "1"

	// Rim lighting parameters
	"$rimlight" "1"			
	"$rimlightexponent" "20"	
	"$rimlightboost" ".4"

	"360?$color2" "[ 0.5 0.5 0.5 ]"

	"$glowcolor"	"1"
	
	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps\cubemap_sheen001"
	"$sheenmapmask" 		"Effects\AnimatedSheen\animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}		
	}
}